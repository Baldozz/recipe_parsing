{
  "name": "Malatang Dressing",
  "ingredients": [
    "80g Knorr Chicken Powder",
    "2000g(2L) Water",
    "45g Peeled Garlic; smashed",
    "45g Spring Onion; smashed",
    "60g Peeled Ginger (trims)",
    "30g Dried Red Chili",
    "20g Sichuan Pepper",
    "10pc Star Anise",
    "10pc Cardamom; cracked",
    "10 pc Bayleaves",
    "75g Rock Sugar",
    "3g Nutmeg",
    "20g Black Pepper",
    "10g Fennel Seeds",
    "266g Doubanjian (Toban Jan) Chili Paste",
    "130g Superior Light Soy"
  ],
  "steps": [
    "Stir all ingredients together in a pot and bring to a quick boil and remove from heat.",
    "Take off heat, let it infuse and cool.",
    "Pass through sieve and reserve."
  ],
  "other_details": {}
}