{
  "name": "Taiwanese Sausage",
  "ingredients": [
    "2 kg Pork belly",
    "Pork fat",
    "250 g Sugar",
    "25 g Salt",
    "100 ml Kao Liang wine",
    "1/2 tsp Cinnamon powder",
    "1/2 tsp Five spice",
    "1/2 tsp White pepper",
    "1/2 tsp Ginger powder",
    "1/2 tsp Garlic powder",
    "1/2 tsp Sichuan pepper ground"
  ],
  "steps": [
    "Coursely mince pork belly",
    "Cut pork fat into 1cm cubes",
    "Mix with all other ingredients well",
    "Put into casing (80g per sausage)",
    "Hang to dry for at least 5 days"
  ],
  "other_details": {}
}