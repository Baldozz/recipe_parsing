{
  "name": "Cheese and Spring Onion Xian Bing",
  "ingredients": [
    "40g Montgomery cheese (from Neal's Yard Dairy)",
    "55g Roasted spring onion chopped",
    "20g Raw Spring onion chopped",
    "2 pinch Salt",
    "1 pinch Grounded black pepper",
    "46g Xian Bing Dough",
    "60g Fillings"
  ],
  "steps": [
    "Roast spring onion in josper",
    "Once outer shell is black, take out and peel",
    "Chop the roasted spring onion",
    "Grate montgomery cheese",
    "Mix everything together"
  ],
  "other_details": {
    "notes": "155g raw spring onion turn into 55g roasted spring onion"
  }
}